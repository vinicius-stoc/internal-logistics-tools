ENVIRONMENT=local
DEBUG=True
SECRET_KEY=change-me
ALLOWED_HOSTS=127.0.0.1,localhost

# Use DATABASE_URL for PostgreSQL when available.
# Example: postgres://user:password@localhost:5432/internal_logistics
DATABASE_URL=
DATABASE_SSL_REQUIRE=False

EXCEL_SOURCE_MODE=local
LOCAL_EXCEL_PATH=data/Acompanhamento Lead Time - Tabaco mes de Maio 2026.xlsx

SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
SFTP_PASSWORD=
SFTP_PRIVATE_KEY=
SFTP_REMOTE_PATH=
SFTP_KNOWN_HOSTS_FINGERPRINT=

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@localhost
